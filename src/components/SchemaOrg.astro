---
import { site, featuredBrands } from '../data/site';
import { services } from '../data/services';

interface Props { schema?: object | null; }
const { schema = null } = Astro.props;

const business = {
  '@context': 'https://schema.org',
  '@type': ['AutoPartsStore', 'AutoRepair', 'LocalBusiness'],
  '@id': site.url + '#business',
  name: site.name,
  description: site.description,
  url: site.url,
  telephone: site.phoneLandlineIntl,
  email: site.email,
  image: site.url + '/images/og-image.jpg',
  logo: site.url + '/logo.png',
  priceRange: '££',
  currenciesAccepted: 'GBP',
  paymentAccepted: ['Cash', 'Debit Card', 'Credit Card', 'Bank Transfer'],
  slogan: site.tagline,
  address: {
    '@type': 'PostalAddress',
    streetAddress: `${site.address.unit}, ${site.address.estate}, ${site.address.street}`,
    addressLocality: site.address.city,
    addressRegion: site.address.region,
    postalCode: site.address.postcode,
    addressCountry: site.address.countryCode,
  },
  geo: { '@type': 'GeoCoordinates', latitude: site.address.lat, longitude: site.address.lng },
  hasMap: site.googleMapsUrl,
  sameAs: [site.ebayUrl],
  areaServed: [
    { '@type': 'Place', name: 'Chadwell Heath' },
    { '@type': 'Place', name: 'Dagenham' },
    { '@type': 'Place', name: 'Romford' },
    { '@type': 'Place', name: 'East London' },
    { '@type': 'Place', name: 'Essex' },
  ],
  openingHoursSpecification: [
    { '@type': 'OpeningHoursSpecification', dayOfWeek: ['Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday'], opens: '08:30', closes: '17:30' },
    { '@type': 'OpeningHoursSpecification', dayOfWeek: ['Saturday'], opens: '08:30', closes: '12:30' },
  ],
  brand: featuredBrands.map((b) => ({ '@type': 'Brand', name: b })),
  knowsAbout: [
    'Car Parts Supply', 'Parts Fitting', 'Car Body Repair', 'Car Spray Paint',
    'Bumpers', 'Bonnets', 'Wings & Fenders', 'Car Lighting', 'Grilles & Trims',
    'Mercedes Parts', 'BMW Parts', 'Audi Parts', 'Lexus Parts', 'Tesla Parts', 'Range Rover Parts', 'Ford Parts',
  ],
  makesOffer: services.map((s) => ({
    '@type': 'Offer',
    itemOffered: { '@type': 'Service', name: s.title, description: s.tagline },
  })),
  aggregateRating: {
    '@type': 'AggregateRating',
    ratingValue: site.rating.value,
    reviewCount: site.rating.count,
    bestRating: 5,
    worstRating: 1,
  },
};
---
<script type="application/ld+json" set:html={JSON.stringify(business)} />
{schema && <script type="application/ld+json" set:html={JSON.stringify(schema)} />}
