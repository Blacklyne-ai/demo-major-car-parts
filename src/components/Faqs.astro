---
import Icon from './Icon.astro';
import { faqs as allFaqs, type Faq } from '../data/content';
interface Props { items?: Faq[]; emitSchema?: boolean; }
const { items = allFaqs, emitSchema = true } = Astro.props;

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: items.map((f) => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
};
---
<div class="max-w-3xl mx-auto space-y-3">
  {items.map((f, i) => (
    <details class="faq group card !p-0 overflow-hidden fade-in" name="faq" open={i === 0}>
      <summary class="flex items-center justify-between gap-4 cursor-pointer list-none p-5 md:p-6 font-semibold text-ink select-none">
        <span class="text-[1.02rem]">{f.q}</span>
        <span class="faq-icon flex-shrink-0 w-8 h-8 rounded-full inline-flex items-center justify-center bg-navy/5 text-orange-deep transition-transform">
          <Icon name="Plus" size={18} strokeWidth={2.4} />
        </span>
      </summary>
      <div class="px-5 md:px-6 pb-5 md:pb-6 -mt-1 text-muted leading-relaxed text-pretty">{f.a}</div>
    </details>
  ))}
</div>

{emitSchema && <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />}

<style>
  .faq summary::-webkit-details-marker { display: none; }
  .faq[open] .faq-icon { transform: rotate(135deg); background: rgb(var(--rgb-orange) / 0.12); }
  .faq[open] { border-color: rgb(var(--rgb-orange) / 0.35); }
</style>
