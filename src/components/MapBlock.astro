---
import Icon from './Icon.astro';
import { site } from '../data/site';
interface Props {
  heading?: string;
  intro?: string;
  showHeading?: boolean;
}
const {
  heading = 'Find us in Chadwell Heath',
  intro = 'We’re on Chadwell Heath Industrial Park, just off Kemp Road — a trade-friendly estate with space to pull in, drop off and collect. Head in off Kemp Road and follow the units round to K2 / K3.',
  showHeading = true,
} = Astro.props;
---
<div class="grid lg:grid-cols-2 gap-8 items-stretch">
  <div class="fade-in flex flex-col">
    {showHeading && (
      <>
        <span class="eyebrow mb-5">How to find us</span>
        <h2 class="heading-md text-ink text-balance mb-4">{heading}</h2>
      </>
    )}
    <p class="text-muted leading-relaxed mb-6 text-pretty">{intro}</p>

    <div class="tile mb-4">
      <div class="flex items-start gap-4">
        <span class="tile-icon tile-icon-orange flex-shrink-0"><Icon name="MapPin" size={22} strokeWidth={2} /></span>
        <address class="not-italic text-ink leading-relaxed">
          <span class="font-semibold">{site.name}</span><br />
          {site.address.unit}, {site.address.estate}<br />
          {site.address.street}, {site.address.city}<br />
          {site.address.region} {site.address.postcode}
        </address>
      </div>
    </div>

    <div class="flex flex-col sm:flex-row gap-3 mt-auto">
      <a href={site.googleDirectionsUrl} target="_blank" rel="noopener" class="btn btn-navy">
        <Icon name="Navigation" size={16} strokeWidth={2.2} />
        Get directions
      </a>
      <a href={site.googleMapsUrl} target="_blank" rel="noopener" class="btn btn-outline">
        <Icon name="MapPinned" size={16} strokeWidth={2.2} />
        Open in Maps
      </a>
    </div>
  </div>

  <div class="fade-in stagger-1 rounded-[1.5rem] overflow-hidden border border-line min-h-[340px] lg:min-h-full" style="box-shadow: var(--shadow-soft);">
    <iframe
      src={site.googleMapsEmbed}
      title={`Map showing ${site.name}, ${site.address.estate}, ${site.address.postcode}`}
      width="100%"
      height="100%"
      style="border:0; min-height: 340px; display:block;"
      loading="lazy"
      referrerpolicy="no-referrer-when-downgrade"
      allowfullscreen
    ></iframe>
  </div>
</div>
