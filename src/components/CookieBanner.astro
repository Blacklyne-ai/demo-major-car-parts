---
// UK GDPR / PECR cookie notice. This static site sets no tracking
// cookies by default — consent is recorded locally (localStorage) only.
---
<div id="cookie-banner" class="fixed bottom-0 left-0 right-0 z-[60] p-3 md:p-4 translate-y-full transition-transform duration-500" style="will-change: transform;">
  <div class="container-mcp">
    <div class="rounded-2xl md:rounded-3xl p-5 md:p-6 flex flex-col md:flex-row md:items-center gap-4 md:gap-6" style="background: rgba(0,18,43,0.95); border: 1px solid rgba(255,255,255,0.12); box-shadow: 0 24px 60px -20px rgba(0,18,43,0.6); backdrop-filter: blur(14px);">
      <div class="flex-1">
        <p class="text-white font-semibold text-sm mb-1 flex items-center gap-2">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#FF6B1F" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><circle cx="8.5" cy="10.5" r="0.6" fill="#FF6B1F"/><circle cx="15" cy="9" r="0.6" fill="#FF6B1F"/><circle cx="14.5" cy="15" r="0.6" fill="#FF6B1F"/><circle cx="9.5" cy="15.5" r="0.6" fill="#FF6B1F"/></svg>
          We value your privacy
        </p>
        <p class="text-white/65 text-[0.82rem] leading-relaxed">
          We use essential cookies to make our site work. With your consent we may also use analytics cookies to understand how the site is used. See our <a href="/cookie-policy" class="text-orange-bright underline underline-offset-2 hover:text-white">Cookie Policy</a>.
        </p>
      </div>
      <div class="flex gap-2.5 flex-shrink-0">
        <button id="cookie-reject" class="btn btn-ghost btn-sm">Reject</button>
        <button id="cookie-accept" class="btn btn-primary btn-sm">Accept all</button>
      </div>
    </div>
  </div>
</div>

<script>
  const KEY = 'mcp-cookie-consent';
  const banner = document.getElementById('cookie-banner');
  const show = () => banner && (banner.style.transform = 'translateY(0)');
  const hide = () => banner && (banner.style.transform = 'translateY(150%)');

  const stored = (() => { try { return localStorage.getItem(KEY); } catch { return 'dismissed'; } })();
  if (!stored) setTimeout(show, 1200);

  const set = (v: string) => { try { localStorage.setItem(KEY, v); } catch {} hide(); };
  document.getElementById('cookie-accept')?.addEventListener('click', () => set('accepted'));
  document.getElementById('cookie-reject')?.addEventListener('click', () => set('rejected'));
</script>
