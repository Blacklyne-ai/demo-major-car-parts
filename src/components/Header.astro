---
import { nav, telLandline, telMobile, whatsappLink, site } from '../data/site';
import Icon from './Icon.astro';
const { current = '' } = Astro.props;

const isActive = (item: typeof nav[number]) =>
  current === item.href ||
  (item.children && item.href !== '/' && current.startsWith(item.href));
---

<header id="site-header" class="fixed top-0 left-0 right-0 z-50">
  <div class="container-mcp pt-4 md:pt-6">
    <div
      id="nav-shell"
      class="flex items-center justify-between gap-3 pl-4 pr-3 md:pl-6 md:pr-3 py-2.5 rounded-pill transition-all duration-500"
      style="background: rgba(255,255,255,0.82); backdrop-filter: blur(20px) saturate(170%); -webkit-backdrop-filter: blur(20px) saturate(170%); border: 1px solid rgba(0,45,98,0.10); box-shadow: 0 1px 2px rgba(0,18,43,0.04), 0 8px 32px -8px rgba(0,45,98,0.18), inset 0 1px 0 0 rgba(255,255,255,0.7);"
    >
      <!-- Logo (original Major Car Parts mark) -->
      <a href="/" class="flex items-center flex-shrink-0" aria-label="Major Car Parts — home">
        <img src="/logo.png" alt="Major Car Parts" width="200" height="81" class="h-8 md:h-9 w-auto" />
      </a>

      <!-- Desktop nav -->
      <nav class="hidden lg:flex items-center gap-0.5" aria-label="Primary">
        {nav.map((item) =>
          item.children ? (
            <div class="nav-dd relative">
              <a href={item.href} class={`nav-pill inline-flex items-center gap-1 ${isActive(item) ? 'active' : ''}`} aria-haspopup="true" aria-expanded="false">
                {item.label}
                <Icon name="ChevronDown" size={14} strokeWidth={2.4} class="nav-dd-chev" />
              </a>
              <div class="nav-dd-panel" role="menu">
                {item.children.map((c) => (
                  <a href={c.href} role="menuitem" class={`nav-dd-item ${current === c.href ? 'active' : ''}`}>{c.label}</a>
                ))}
              </div>
            </div>
          ) : (
            <a href={item.href} class={`nav-pill ${isActive(item) ? 'active' : ''}`}>{item.label}</a>
          )
        )}
      </nav>

      <!-- Right cluster -->
      <div class="flex items-center gap-2">
        <span id="live-status" class="hidden 2xl:inline-flex items-center gap-2 px-3 py-1.5 rounded-full text-[0.72rem] font-medium" style="background: rgba(0,45,98,0.04); border: 1px solid rgba(0,45,98,0.10); color: rgba(0,45,98,0.78);">
          <span id="live-dot" class="status-dot status-dot-closed"></span>
          <span id="live-text">Checking hours…</span>
        </span>

        <a href={telLandline} class="btn btn-outline btn-sm hidden xl:inline-flex" aria-label={`Call our landline ${site.phoneLandline}`}>
          <Icon name="Phone" size={14} strokeWidth={2.2} />
          {site.phoneLandline}
        </a>
        <a href={telMobile} class="btn btn-primary btn-sm hidden md:inline-flex" aria-label={`Call our mobile ${site.phoneMobile}`}>
          <Icon name="Phone" size={14} strokeWidth={2.2} />
          {site.phoneMobile}
        </a>
        <a href={whatsappLink} target="_blank" rel="noopener" class="btn btn-whatsapp btn-sm !px-3 hidden sm:inline-flex" aria-label="Message us on WhatsApp">
          <Icon name="MessageCircle" size={16} strokeWidth={2.2} />
        </a>

        <button id="menu-toggle" class="lg:hidden p-2.5 rounded-full transition" style="color: #002D62;" aria-label="Open menu" aria-expanded="false" aria-controls="mobile-menu">
          <span class="hamburger" aria-hidden="true"><span></span><span></span><span></span></span>
        </button>
      </div>
    </div>
  </div>

  <!-- Mobile menu (light overlay) -->
  <div id="mobile-menu" class="hidden lg:hidden mt-2 mx-4 rounded-3xl overflow-hidden" style="background: rgba(255,255,255,0.98); backdrop-filter: blur(22px); border: 1px solid rgba(0,45,98,0.10); box-shadow: 0 30px 60px -20px rgba(0,18,43,0.3);">
    <nav class="flex flex-col p-4" aria-label="Mobile">
      {nav.map((item) => (
        <Fragment>
          <a href={item.href} class="py-3 px-2 text-ink/85 hover:text-ink border-b border-navy/10 font-semibold transition" style={current === item.href ? 'color:#BF3D00' : ''}>{item.label}</a>
          {item.children && (
            <div class="flex flex-col pl-4 border-b border-navy/10">
              {item.children.filter((c) => c.href !== item.href).map((c) => (
                <a href={c.href} class="py-2.5 px-2 text-sm text-muted hover:text-orange-deep transition" style={current === c.href ? 'color:#BF3D00' : ''}>{c.label}</a>
              ))}
            </div>
          )}
        </Fragment>
      ))}
      <div class="grid grid-cols-2 gap-2 mt-4">
        <a href={telLandline} class="btn btn-outline btn-sm">
          <Icon name="Phone" size={14} strokeWidth={2.2} /> Landline
        </a>
        <a href={telMobile} class="btn btn-primary btn-sm">
          <Icon name="Phone" size={14} strokeWidth={2.2} /> Mobile
        </a>
      </div>
      <a href={whatsappLink} target="_blank" rel="noopener" class="btn btn-whatsapp btn-sm btn-block mt-2">
        <Icon name="MessageCircle" size={16} strokeWidth={2.2} /> WhatsApp us
      </a>
    </nav>
  </div>
</header>

<style>
  .hamburger { display: inline-flex; flex-direction: column; justify-content: center; gap: 4px; width: 22px; height: 22px; }
  .hamburger span { display: block; width: 22px; height: 2px; background: #FF5500; border-radius: 2px; transition: transform 0.4s cubic-bezier(0.68,-0.55,0.27,1.55), opacity 0.25s ease; transform-origin: center; }
  .hamburger.open span:nth-child(1) { transform: translateY(6px) rotate(45deg); }
  .hamburger.open span:nth-child(2) { opacity: 0; transform: scaleX(0); }
  .hamburger.open span:nth-child(3) { transform: translateY(-6px) rotate(-45deg); }

  /* Services dropdown */
  .nav-dd-panel {
    position: absolute; top: calc(100% + 10px); left: 50%; transform: translateX(-50%) translateY(8px);
    min-width: 220px; padding: 0.5rem; border-radius: 18px;
    background: rgba(255,255,255,0.97); border: 1px solid rgba(0,45,98,0.1);
    backdrop-filter: blur(22px) saturate(170%); -webkit-backdrop-filter: blur(22px) saturate(170%);
    box-shadow: 0 20px 44px -16px rgba(0,18,43,0.28), inset 0 1px 0 0 rgba(255,255,255,0.7);
    opacity: 0; visibility: hidden; transition: opacity 0.25s ease, transform 0.25s ease;
    z-index: 60;
  }
  /* transparent bridge across the 10px gap so the pointer can travel from
     the trigger onto the panel without losing :hover (no premature close) */
  .nav-dd-panel::before { content: ""; position: absolute; left: 0; right: 0; top: -14px; height: 16px; }
  .nav-dd:hover .nav-dd-panel,
  .nav-dd:focus-within .nav-dd-panel { opacity: 1; visibility: visible; transform: translateX(-50%) translateY(0); }
  .nav-dd:hover .nav-dd-chev { transform: rotate(180deg); }
  .nav-dd-item {
    display: block; padding: 0.6rem 0.85rem; border-radius: 11px; font-size: 0.9rem; font-weight: 600;
    color: rgba(0,45,98,0.78); transition: background 0.2s ease, color 0.2s ease;
  }
  .nav-dd-item:hover { background: rgba(255,85,0,0.08); color: #BF3D00; }
  .nav-dd-item.active { color: #BF3D00; background: rgba(255,85,0,0.06); }
  .nav-dd-chev { transition: transform 0.3s ease; }
</style>

<!-- is:inline so the menu toggle attaches at parse time (no module-load race; the first tap always works) -->
<script is:inline>
  (function () {
    var toggle = document.getElementById('menu-toggle');
    var menu = document.getElementById('mobile-menu');
    var shell = document.getElementById('nav-shell');
    var header = document.getElementById('site-header');
    var burger = toggle ? toggle.querySelector('.hamburger') : null;

    function isOpen() { return menu && !menu.classList.contains('hidden'); }
    function setOpen(open) {
      if (!menu) return;
      menu.classList.toggle('hidden', !open);
      if (burger) burger.classList.toggle('open', open);
      if (toggle) {
        toggle.setAttribute('aria-expanded', open ? 'true' : 'false');
        toggle.setAttribute('aria-label', open ? 'Close menu' : 'Open menu');
      }
      document.body.style.overflow = open ? 'hidden' : '';
    }

    if (toggle) {
      toggle.addEventListener('click', function (e) { e.stopPropagation(); setOpen(!isOpen()); });
    }
    if (menu) {
      menu.querySelectorAll('a').forEach(function (a) {
        a.addEventListener('click', function () { setOpen(false); });
      });
    }
    // Close on Escape, on tap outside the header, and when resized up to desktop.
    document.addEventListener('keydown', function (e) { if (e.key === 'Escape' && isOpen()) setOpen(false); });
    document.addEventListener('click', function (e) { if (isOpen() && header && !header.contains(e.target)) setOpen(false); });
    window.addEventListener('resize', function () { if (window.innerWidth >= 1024 && isOpen()) setOpen(false); });

    // Nav strengthen / shrink on scroll
    var ticking = false;
    window.addEventListener('scroll', function () {
      if (ticking) return;
      ticking = true;
      requestAnimationFrame(function () {
        var y = window.scrollY;
        if (shell) {
          if (y > 30) { shell.style.background = 'rgba(255,255,255,0.92)'; shell.style.transform = 'scale(0.985)'; }
          else { shell.style.background = 'rgba(255,255,255,0.82)'; shell.style.transform = 'scale(1)'; }
        }
        ticking = false;
      });
    });

    // Live open/closed status — Mon–Fri 08:30–17:30, Sat 08:30–12:30, Sun closed.
    // Updates on load and every 60s (per brief). Styled CSS dots, no emoji.
    function updateStatus() {
      var dot = document.getElementById('live-dot');
      var text = document.getElementById('live-text');
      if (!dot || !text) return;
      var now = new Date();
      var day = now.getDay();
      var mins = now.getHours() * 60 + now.getMinutes();
      var OPEN = 8 * 60 + 30, CLOSE_WK = 17 * 60 + 30, CLOSE_SAT = 12 * 60 + 30;
      var open = false, msg = '';
      if (day === 0) {
        msg = 'Closed · Opens Monday 8:30am';
      } else if (day === 6) {
        if (mins < OPEN) msg = 'Opens 8:30am today';
        else if (mins < CLOSE_SAT) { open = true; msg = 'Open now · Closes 12:30pm'; }
        else msg = 'Closed · Opens Monday 8:30am';
      } else {
        if (mins < OPEN) msg = 'Opens 8:30am today';
        else if (mins < CLOSE_WK) { open = true; msg = 'Open now · Closes 5:30pm'; }
        else if (day === 5) msg = 'Closed · Opens Saturday 8:30am';
        else msg = 'Closed · Opens 8:30am tomorrow';
      }
      text.textContent = msg;
      dot.className = open ? 'status-dot status-dot-open' : 'status-dot status-dot-closed';
    }
    updateStatus();
    setInterval(updateStatus, 60000);
  })();
</script>
